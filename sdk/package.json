{
  "name": "tobiifree-sdk-ts",
  "version": "0.0.0",
  "description": "TypeScript SDK for the Tobii ET5 eye tracker (WebUSB / Node)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./nodeusb": "./src/nodeusb.ts",
    "./gusb": "./src/gusb.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "usb": "^2.15.0"
  },
  "peerDependenciesMeta": {
    "usb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/w3c-web-usb": "^1.0.10",
    "typescript": "^5.6.3"
  }
}
